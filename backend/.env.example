MONGO_URI=mongodb://localhost:27017/hr-me
PORT=5000

# LLM (OpenAI-compatible). Recommended free tier: https://console.groq.com — create API key
LLM_API_KEY=
# Optional overrides (defaults suit Groq):
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# OpenAI example:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Optional: Microsoft Edge neural TTS (free, no key) — used by POST /api/tts/speak
# TTS_EDGE_VOICE=en-US-AriaNeural
# TTS_EDGE_LANG=en-US
# TTS_EDGE_DISABLE=0
